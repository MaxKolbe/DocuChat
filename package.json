  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "npm install --include=dev && npx tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "watch": "npx tsc -w",
    "seed": "tsx prisma/seed.ts",
    "db:gen": "npx prisma generate",
    "db:mig": "npx prisma migrate dev --name genericname",
    "db:mig-prod": "npx prisma migrate deploy"
