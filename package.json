{
  "name": "docuchat",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "npm install --include=dev && npx tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "watch": "npx tsc -w",
    "seed": "tsx prisma/seed.ts",
    "db:gen": "npx prisma generate",
    "db:mig": "npx prisma migrate dev --name genericname",
    "db:mig-prod": "npx prisma migrate deploy",
    "db:gen-mig": "npx prisma generate && npx prisma migrate dev --name genericname"
  },
  "repository": {
    "type": "git",
